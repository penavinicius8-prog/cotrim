# ============================================================
#  Cotrim Advogados — URLs limpas (servir .html sem a extensão)
#  Se por acaso algo quebrar no host, basta APAGAR este arquivo
#  que o site volta a funcionar com os endereços .html normais.
# ============================================================

Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1) tira a barra final (menos em diretórios): /pagina/  ->  /pagina
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteRule ^ %1 [R=301,L]

  # 2) index e index.html  ->  raiz (/)
  RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
  RewriteRule ^ / [R=301,L]

  # 3) /pagina.html  ->  /pagina   (301: evita conteúdo duplicado no Google)
  RewriteCond %{THE_REQUEST} \s/+([^.\s?/]+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # 4) internamente, serve /pagina a partir do arquivo /pagina.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>
